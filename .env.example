# 네이버 개발자 센터 (https://developers.naver.com)
NAVER_CLIENT_ID=발급받은_클라이언트_아이디
NAVER_CLIENT_SECRET=발급받은_클라이언트_시크릿

# 네이버 계정 — 리뷰 VOC 수집 전용 (실 로그인 필요)
# 보안: 전용 계정 사용 권장 (메인 계정 사용 지양)
NAVER_ID=네이버_아이디
NAVER_PW=네이버_비밀번호

# Google Sheets — 서비스 계정 키 경로
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# Google Sheets — 3개 파일 분리 구조
# URL 예시: https://docs.google.com/spreadsheets/d/<여기_ID>/edit
# 파일 1: 마켓 가격 & 상품가격 (product_prices, shopping_keyword)
GOOGLE_SHEET_MARKET_PRICE_ID=구글시트_파일1_ID

# 파일 2: 거시 트렌드 (search_trend, shopping_category*)
GOOGLE_SHEET_MACRO_TREND_ID=구글시트_파일2_ID

# 파일 3: 리뷰 VOC (review_data, collect_log)
GOOGLE_SHEET_REVIEW_VOC_ID=구글시트_파일3_ID

# LLM API — AI 데일리 리포트 생성 (jobs/generate_daily_report.py)
# Gemini 우선 사용. 없으면 OpenAI로 자동 fallback.

# [권장] Google Gemini (Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=AIza...your_gemini_key...
GEMINI_MODEL=gemini-2.0-flash

# [대안] OpenAI
OPENAI_API_KEY=sk-...your_openai_key...
OPENAI_MODEL=gpt-4o-mini

# Google Drive — 과거 데이터 백업 폴더
# 드라이브 폴더 URL: https://drive.google.com/drive/folders/<여기_ID>
# 서비스 계정에 해당 폴더의 편집자 권한을 부여해야 합니다.
GOOGLE_DRIVE_BACKUP_FOLDER_ID=드라이브_백업_폴더_ID
